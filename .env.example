# ==================== GENERAL ====================
NODE_ENV=development

# ==================== API GATEWAY ====================
API_GATEWAY_PORT=4000
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ==================== EVENT INGESTION ====================
EVENT_INGESTION_PORT=3001

# ==================== QUERY SERVICE ====================
QUERY_SERVICE_PORT=3003

# ==================== KAFKA ====================
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=analytics-platform
KAFKA_GROUP_ID=analytics-worker-group
KAFKA_TOPICS_USER_EVENTS=user-events
KAFKA_TOPICS_USER_EVENTS_DLQ=user-events-dlq
KAFKA_PARTITIONS=10
KAFKA_REPLICATION_FACTOR=1

# ==================== POSTGRESQL ====================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=analytics
POSTGRES_PASSWORD=analytics123
POSTGRES_DB=analytics_db
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10

# ==================== MONGODB ====================
MONGODB_URI=mongodb://analytics:analytics123@localhost:27017/analytics_db?authSource=admin
MONGODB_POOL_SIZE=10

# ==================== REDIS ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=analytics123
REDIS_DB=0
REDIS_CACHE_TTL=300

# ==================== ELASTICSEARCH ====================
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_INDEX_EVENTS=user-events
ELASTICSEARCH_MAX_RETRIES=3

# ==================== OBSERVABILITY ====================
LOG_LEVEL=info
ENABLE_METRICS=true
ENABLE_TRACING=false
